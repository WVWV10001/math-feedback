# ==============================
# 数学教学反馈工具 — .gitignore
# 标准：Node.js + Windows + PWA
# ==============================

# ── Node.js ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── 环境变量 & 密钥 ──
.env
.env.local
.env.*.local
*.key
*.pem
secrets.*
credentials.*

# ── 运行时 & 缓存 ──
dist/
build/
.cache/
*.tmp
*.temp

# ── 日志 ──
logs/
*.log

# ── 编辑器 ──
.vscode/
.idea/
*.sublime-workspace
*.sublime-project
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Windows 系统文件 ──
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.stackdump
[Dd]esktop.ini

# ── macOS 系统文件（预防同事用 Mac）──
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?

# ── Linux 系统文件 ──
.directory
*~

# ── AI 工具 & Claude Code ──
.claude/
.agents/
.claude.json
.cc-switch/
.copilot/

# ── 用户个人配置 ──
.ssh/
.gitconfig
.heyboxacc.conf
.node_repl_history
ntuser*

# ── 备份文件（开发过程自动生成的备份）──
*_backup_*.html
*_backup_*.js
*_backup_*.css
*.bak

# ── 压缩包 ──
*.7z
*.rar
*.zip
*.tar
*.gz
*.xz

# ── 导出数据文件（含真实学生数据，绝对不能上传）──
*.json.bak
data_export*.json
students_export*.json

# ── 快捷方式 ──
*.lnk

# ── 私人文件 ──
萤火虫.html
